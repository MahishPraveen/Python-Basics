print("EXPENSE TRACKER")

expenses=[]

while True:

    print("1. Add Expense")
    print("2. View Expenses")
    print("3. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        amount = float(input("Enter amount: "))
        expenses.append(amount)
        print("Expense Added")

    elif choice == "2":
        print("Expenses:", expenses)
        print("Total Expense =", sum(expenses))

    elif choice == "3":
        print("Program Ended")
        break

    else:
        print("Invalid Choice")
